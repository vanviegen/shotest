{
  "name": "shotest",
  "version": "1.5.0",
  "description": "Screenshot testing for Playwright. Capture, compare, review.",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "author": "Frank van Viegen BV",
  "files": [
    "build",
    "build.frontend",
    "src",
    "README.md",
    "skill"
  ],
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "bin": {
    "shotest": "./build/cli.js"
  },
  "scripts": {
    "build": "node --experimental-strip-types scripts/build.ts && npm run build:docs",
    "build:docs": "readme-tsdoc && rm -rf skill ; mkdir skill ; cat skill-header.md README.md > skill/SKILL.md",
    "test": "npm --prefix test-project run test:run",
    "review": "npm run build && node build/cli.js review",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "odiff-bin": "^4.3.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.0.3",
    "aberdeen": "^1.9.0",
    "readme-tsdoc": "^1.1.7",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
