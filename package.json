{
  "name": "shotest",
  "version": "1.1.1",
  "description": "Screenshot testing for Playwright. Capture, compare, review.",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "author": "Frank van Viegen BV",
  "files": [
    "bin",
    "build",
    "src",
    "README.md",
    "skill"
  ],
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "bin": {
    "shotest": "./bin/cli.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs && npm run build:docs",
    "build:docs": "readme-tsdoc && rm -rf skill ; mkdir skill ; cat skill-header.md README.md > skill/SKILL.md",
    "test": "npm --prefix test-project run test:run && node scripts/test-project-compare.mjs",
    "review": "npm run build && node build/review.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "readme-tsdoc": "^1.1.7",
    "aberdeen": "^1.9.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
