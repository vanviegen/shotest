{
  "name": "shotest",
  "version": "0.1.0",
  "description": "Screenshot testing for Playwright. Capture, compare, review.",
  "type": "module",
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./video": "./src/video.ts"
  },
  "bin": {
    "shotest": "./bin/review.mjs"
  },
  "scripts": {
    "build": "node scripts/build-review-ui.mjs",
    "review": "npm run build && node --experimental-strip-types src/review.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "aberdeen": "^1.9.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
